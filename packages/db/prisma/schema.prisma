// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

enum RetentionPolicy {
    ONE_YEAR
    SIX_MONTHS
    THIRTY_DAYS
    MANUAL_ONLY
}

model User {
    id              String          @id @default(uuid())
    name            String?
    email           String          @unique
    emailVerified   DateTime?
    password        String?
    image           String?
    retentionPolicy RetentionPolicy @default(ONE_YEAR)
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt

    accounts    Account[]
    sessions    Session[]
    chats       ChatSession[]
    preferences UserPreferences?
}

model Account {
    id                String  @id @default(uuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(uuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model ChatSession {
    id        String   @id @default(uuid())
    title     String?
    userId    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    messages    Message[]
    emotionLogs EmotionLog[]

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
    id            String   @id @default(uuid())
    chatSessionId String
    role          String
    parts         Json
    createdAt     DateTime @default(now())

    chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
}

model UserPreferences {
    id            String  @id @default(uuid())
    userId        String  @unique

    // ── AI Provider ──────────────────────────────────────────────────────────
    /// Identifier of the AI service provider.
    /// Values: "xiaomi" | "openai" | "deepseek" | "custom"
    aiProvider    String  @default("xiaomi")
    /// Model identifier within the chosen provider (e.g. "gpt-4o", "deepseek-chat").
    aiModel       String  @default("mimo-v2-flash")
    /// Encrypted user-supplied API key (null for built-in providers).
    aiApiKey      String?
    /// Base URL for OpenAI-compatible custom providers.
    aiBaseUrl     String?

    // ── Chat Experience ───────────────────────────────────────────────────────
    /// The name Eveheart uses to refer to itself in conversation.
    personaName   String  @default("Eveheart")
    /// BCP-47 language tag for AI reply language. "auto" follows user input.
    replyLanguage String  @default("zh-CN")
    /// Whether the text-to-speech voice feature is enabled.
    voiceEnabled  Boolean @default(true)
    /// Voice playback speed. Values: "slow" | "normal" | "fast"
    voiceSpeed    String  @default("normal")

    // ── Display & Accessibility ───────────────────────────────────────────────
    /// Interface font size preset. Values: "standard" | "large" | "xl" | "xxl"
    fontSize      String  @default("standard")
    /// Enables elderly-friendly mode (forces xxl font + simplified UI).
    elderlyMode   Boolean @default(false)
    /// Enables high-contrast display for visually impaired users.
    highContrast  Boolean @default(false)

    // ── Notifications ─────────────────────────────────────────────────────────
    /// Whether periodic emotion check-in reminders are active.
    reminderEnabled Boolean @default(false)
    /// Local time for daily reminder in HH:MM format (e.g. "20:00").
    reminderTime    String  @default("20:00")
    /// Reminder recurrence. Values: "daily" | "weekdays" | "weekly"
    reminderFreq    String  @default("daily")

    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmotionLog {
    id            String   @id @default(uuid())
    chatSessionId String
    emotion       String
    score         Float
    source        String
    createdAt     DateTime @default(now())

    chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
}
