{
  "name": "eveheart",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter @eveheart/web dev",
    "build": "pnpm --filter @eveheart/web build",
    "start": "pnpm --filter @eveheart/web start",
    "lint": "pnpm --filter @eveheart/web lint",
    "db:generate": "node packages/db/scripts/schema-workflow.cjs generate",
    "db:push": "node packages/db/scripts/schema-workflow.cjs push",
    "db:deploy": "node packages/db/scripts/schema-workflow.cjs deploy",
    "db:migrate": "pnpm --filter @eveheart/db db:migrate",
    "db:studio": "pnpm --filter @eveheart/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
