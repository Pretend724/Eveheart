FROM node:22-bookworm-slim

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/package.json
COPY packages/db/package.json ./packages/db/package.json
COPY packages/rag-db/package.json ./packages/rag-db/package.json

RUN pnpm install --frozen-lockfile

# Personal-use image: keep local .env files inside the image.
COPY . .

RUN pnpm --filter @eveheart/db db:generate
RUN pnpm --filter @eveheart/web build

RUN chmod +x ./docker/start-web.sh

EXPOSE 3000

CMD ["./docker/start-web.sh"]
