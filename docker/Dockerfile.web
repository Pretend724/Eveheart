FROM node:22-bookworm-slim

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/package.json
COPY packages/db/package.json ./packages/db/package.json
COPY packages/rag-db/package.json ./packages/rag-db/package.json

RUN pnpm install --frozen-lockfile

COPY .env ./.env
COPY apps/web ./apps/web
COPY packages/db ./packages/db
COPY packages/rag-db ./packages/rag-db
COPY docker/start-web.sh ./docker/start-web.sh

RUN pnpm --filter @eveheart/db db:generate
RUN pnpm --filter @eveheart/web build

RUN chmod +x ./docker/start-web.sh

EXPOSE 3000

CMD ["./docker/start-web.sh"]
